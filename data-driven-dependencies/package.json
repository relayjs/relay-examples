{
  "name": "with-relay-modern",
  "version": "1.0.0",
  "description": "Example of Next.js with Relay Modern",
  "scripts": {
    "next": "next",
    "dev": "mkdir -p __generated__ && touch queryMap.json && tsx ./schema/printSchema.ts && concurrently \"next\" \"relay-compiler --watch\"",
    "build": "next build",
    "start": "next start",
    "relay": "relay-compiler",
    "schema": "tsx ./schema/printSchema.ts",
    "prettier": "prettier --write '{,!(node_modules|__generated__|\\.next)/**}*.{ts,tsx,json}'"
  },
  "license": "MIT",
  "dependencies": {
    "chance": "^1.1.8",
    "graphql": "^16.3.0",
    "next": "^16.0.0",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-relay": "^21.0.0",
    "relay-runtime": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.0",
    "relay-compiler": "^21.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "prettier": {
    "bracketSameLine": true,
    "bracketSpacing": false,
    "singleQuote": true,
    "trailingComma": "all"
  }
}
